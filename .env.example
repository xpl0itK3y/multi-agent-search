# Ваш API ключ DeepSeek
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_MODEL=deepseek-chat
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=multi-agent-search-dev
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
TASK_STORE_BACKEND=postgres
# ALLOW_MEMORY_TASK_STORE=false
# SMOKE_ANALYZER_REPORT=smoke final report

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=multi_agent_search
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
FINALIZE_WORKER_INTERVAL=2.0
# DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/multi_agent_search
